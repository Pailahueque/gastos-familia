<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Expense Splitter</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6f8;
padding:30px;
}

.container{
max-width:1100px;
margin:auto;
}

h1{
margin-bottom:20px;
color:#222;
}

.card{
background:white;
padding:20px;
border-radius:12px;
margin-bottom:20px;
box-shadow:0 5px 15px rgba(0,0,0,.08);
}

input,select,button{
padding:10px;
margin:5px;
border-radius:8px;
border:1px solid #ccc;
}

button{
background:#22c55e;
color:white;
border:none;
cursor:pointer;
}

button:hover{
background:#16a34a;
}

ul{
list-style:none;
margin-top:10px;
}

li{
padding:8px;
border-bottom:1px solid #eee;
}

table{
width:100%;
border-collapse:collapse;
margin-top:15px;
}

td,th{
padding:10px;
border-bottom:1px solid #ddd;
text-align:left;
}

.balance-positive{
color:green;
font-weight:bold;
}

.balance-negative{
color:red;
font-weight:bold;
}
</style>
</head>

<body>

<div class="container">

<h1>💰 Expense Splitter</h1>

<div class="card">

<h2>Participantes</h2>

<input id="personName" placeholder="Nombre">

<button onclick="addPerson()">Agregar</button>

<ul id="peopleList"></ul>

</div>

<div class="card">

<h2>Nuevo gasto</h2>

<input id="description" placeholder="Descripción">

<input id="amount" type="number" placeholder="Monto">

<select id="payer"></select>

<button onclick="addExpense()">Guardar gasto</button>

</div>

<div class="card">

<h2>Gastos</h2>

<table>

<thead>

<tr>

<th>Descripción</th>

<th>Monto</th>

<th>Pagó</th>

</tr>

</thead>

<tbody id="expensesTable"></tbody>

</table>

</div>

<div class="card">

<h2>Balances</h2>

<ul id="balances"></ul>

</div>

</div>

<script>

let people=JSON.parse(localStorage.getItem("people"))||[];

let expenses=JSON.parse(localStorage.getItem("expenses"))||[];

function save(){

localStorage.setItem("people",JSON.stringify(people));

localStorage.setItem("expenses",JSON.stringify(expenses));

}

function renderPeople(){

let list=document.getElementById("peopleList");

let payer=document.getElementById("payer");

list.innerHTML="";

payer.innerHTML="";

people.forEach((p,i)=>{

list.innerHTML+=`<li>${p}</li>`;

payer.innerHTML+=`<option value="${i}">${p}</option>`;

});

}

function addPerson(){

let name=document.getElementById("personName").value.trim();

if(!name)return;

people.push(name);

document.getElementById("personName").value="";

save();

renderPeople();

calculate();

}

function addExpense(){

let desc=document.getElementById("description").value;

let amount=parseFloat(document.getElementById("amount").value);

let payer=document.getElementById("payer").value;

if(!desc||!amount)return;

expenses.push({

desc,

amount,

payer:Number(payer)

});

document.getElementById("description").value="";

document.getElementById("amount").value="";

save();

renderExpenses();

calculate();

}

function renderExpenses(){

let table=document.getElementById("expensesTable");

table.innerHTML="";

expenses.forEach(e=>{

table.innerHTML+=`

<tr>

<td>${e.desc}</td>

<td>$${e.amount.toFixed(2)}</td>

<td>${people[e.payer]}</td>

</tr>

`;

});

}

function calculate(){

let balances=new Array(people.length).fill(0);

expenses.forEach(e=>{

let share=e.amount/people.length;

balances[e.payer]+=e.amount;

for(let i=0;i<people.length;i++){

balances[i]-=share;

}

});

let ul=document.getElementById("balances");

ul.innerHTML="";

balances.forEach((b,i)=>{

ul.innerHTML+=`

<li class="${b>=0?'balance-positive':'balance-negative'}">

${people[i]} :

${b>=0?'+':''}$${b.toFixed(2)}

</li>

`;

});

}

renderPeople();

renderExpenses();

calculate();

</script>

</body>
</html>
